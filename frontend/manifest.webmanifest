{
  "name": "Cotai",
  "short_name": "Cotai",
  "id": "/dashboard.html",
  "description": "Cotai no celular com notificacoes de cotacao e acompanhamento de pedidos.",
  "start_url": "/dashboard.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#060a09",
  "theme_color": "#060a09",
  "lang": "pt-BR",
  "categories": ["business", "productivity", "utilities"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/assets/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Nova cota",
      "short_name": "Cota",
      "url": "/new-request.html",
      "icons": [
        {
          "src": "/assets/favicon.svg",
          "sizes": "any",
          "type": "image/svg+xml"
        }
      ]
    },
    {
      "name": "Pedidos",
      "short_name": "Pedidos",
      "url": "/requests.html",
      "icons": [
        {
          "src": "/assets/favicon.svg",
          "sizes": "any",
          "type": "image/svg+xml"
        }
      ]
    }
  ]
}
